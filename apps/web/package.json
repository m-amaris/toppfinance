{
  "name": "@toppfinance/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @toppfinance/shared && vite --host 0.0.0.0 --port 5175",
    "build": "npm run build -w @toppfinance/shared && tsc -p tsconfig.node.json && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4175",
    "test": "npm run build -w @toppfinance/shared && vitest run",
    "check": "npm run build -w @toppfinance/shared && tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.2",
    "@testing-library/user-event": "^14.6.1",
    "@toppfinance/shared": "file:../../packages/shared",
    "lucide-react": "^0.525.0",
    "msw": "^2.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.1",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.4.21",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
