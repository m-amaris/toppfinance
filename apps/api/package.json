{
  "name": "@toppfinance/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run build -w @toppfinance/shared && tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "npm run build -w @toppfinance/shared && vitest run --passWithNoTests",
    "test:coverage": "npm run build -w @toppfinance/shared && vitest run --coverage",
    "check": "npm run build -w @toppfinance/shared && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.1.0",
    "@fastify/rate-limit": "^11.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/swagger": "^9.8.0",
    "@fastify/swagger-ui": "^6.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@prisma/client": "^6.13.0",
    "@toppfinance/shared": "file:../../packages/shared",
    "csv-parse": "^5.6.0",
    "dotenv": "^17.2.1",
    "fastify": "^5.4.0",
    "nanoid": "^5.1.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "testcontainers": "^12.0.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  }
}
