NODE_ENV=development
APP_NAME=ToppFinance
APP_URL=https://toppfinance
PORT=3000
DATABASE_URL=postgresql://toppfinance:toppfinance@localhost:5432/toppfinance?schema=public
SESSION_COOKIE_NAME=toppfinance_session
SESSION_TTL_DAYS=365
COOKIE_SECURE=true
CORS_ORIGIN=https://toppfinance,http://localhost:5175
BACKUP_DIR=./backups
BACKUP_RETENTION_WEEKS=30
BACKUP_SCHEDULE_CRON=0 3 * * 0
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=openai/gpt-5-mini
OPENROUTER_FALLBACK_MODELS=anthropic/claude-sonnet-4.5,google/gemini-3-flash-preview
OPENROUTER_ZDR=true
SEED_ADMIN_EMAIL=miguel.amaris.martos@gmail.com
SEED_ADMIN_NAME=Miguel
SEED_ADMIN_PASSWORD=
